<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <servlet>
    <servlet-name>hola</servlet-name>
    <servlet-class>org.jfcmc.servlet.chap02.HolaWWW</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>hola3</servlet-name>
    <servlet-class>org.jfcmc.servlet.chap02.HolaWWW3</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>show-message</servlet-name>
    <servlet-class>org.jfcmc.servlet.chap02.ShowMessage</servlet-class>
    <init-param>
      <param-name>message</param-name>
      <param-value>Shibboleth</param-value>
    </init-param>
    <init-param>
      <param-name>times</param-name>
      <param-value>10</param-value>
    </init-param>
  </servlet>
    <servlet>
    <servlet-name>lottery-numbers</servlet-name>
    <servlet-class>org.jfcmc.servlet.chap02.LotteryNumbers</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>hola</servlet-name>
    <url-pattern>/hola</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>hola3</servlet-name>
    <url-pattern>/hola3</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>show-message</servlet-name>
    <url-pattern>/message</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>lottery-numbers</servlet-name>
    <url-pattern>/lottery</url-pattern>
  </servlet-mapping>
</web-app>
