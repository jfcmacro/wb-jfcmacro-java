<?xml version="1.0" encoding="ISO-8859-1"?>
<project name="GenericSwtApplication" default="run" basedir=".">
  <description>
    Generic SWT Application build and execution file
  </description>

  <property name="main.class" value=""/>
  <property name="src"        location="."/>
  <property name="build"      location="."/>

  <!-- Update locaiton to match your eclipse home directory -->
  <property name="ecl.home" location="/opt/eclipse"/>

  <!-- Update value to match your windowing system (win32, gtk, motif, etc.) -->
  <property name="win.sys"  value="gtk"/>

  <!-- Update value to match you os (win32, linux, etc.) -->
  <property name="os.sys"   value="linux"/>

  <!-- Update value to match you architecture -->
  <property name="arch" value="x86"/>

  <!-- Update value to match you SWT version -->
  <property name="swt.ver" value="3.2.1"/>

  <!-- Update value to match you SWT release -->
  <property name="swt.release" value=".v3235"/>

  <!-- Do not edit below this line -->
  <property name="swt.subdir" location="${ecl.home}/plugins/org.eclipse.swt.${win.sys}_${swt.ver}${swt.release}"/>
  <property name="swt.jar.lib" location="${swt.subdir}"/>
  <property name="swt.jni.lib" location="${ecl.home}/plugins/org.eclipse.swt_${swt.ver}${swt.release}e"/>

  <!-- Do not edit below this line -->
  <property name="jface.subdir" location="${ecl.home}/plugins/org.eclipse.jface_3.2.1"/>
  <property name="jface.jar.lib" location="${jface.subdir}"/>

  <path id="project.class.path">
    <pathelement path="${build}"/>
    <fileset dir="${swt.jar.lib}">
      <include name="**/*.jar"/>
    </fileset>
    <fileset dir="${jface.jar.lib}">
      <include name="**/*.jar"/>
    </fileset>
  </path>

  <target name="compile">
    <javac srcdir="${src}" destdir="${build}">
      <classpath refid="project.class.path"/>
    </javac>
  </target>

  <target name="run" depends="compile">
    <java classname="${main.class}" fork="true" failonerror="true">
       <jvmarg value="-Djava.library.path=${swt.jni.lib}"/>
       <classpath refid="project.class.path"/>
    </java>
  </target>
</project>