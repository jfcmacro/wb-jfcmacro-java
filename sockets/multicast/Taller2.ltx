\section*{ Programa de multidifusión}
\begin{verbatim}
 1: import java.net.*;
 2: import java.io.*;
 3: 
 4: public class MulticastSniffer {
 5: 
 6:     public static void main(String[] args) {
 7: 	
 8: 	InetAddress group = null;
 9: 	int port = 0;
10: 
11: 	// Lee la direcciĂłn de la lĂ­nea de comandos
12: 
13: 	try {
14: 
15: 	    group = InetAddress.getByName(args[0]);
16: 	    port = Integer.parseInt(args[1]);
17: 	    
18: 	} catch (Exception e) {
19: 
20: 	    System.err.println("Usage: java MulticastSniffer multicast_address port");
21: 	    System.exit(1);
22: 	}
23: 
24: 	MulticastSocket ms = null;
25: 
26: 	try {
27: 	    
28: 	    ms = new MulticastSocket(port);
29: 	    ms.joinGroup(group);
30: 
31: 	    byte[] buffer = new byte[8192];
32: 	    while (true) {
33: 		DatagramPacket dp = new DatagramPacket(buffer, buffer.length);
34: 		ms.receive(dp);
35: 		String s = new String(dp.getData());
36: 		System.out.println(s);
37: 	    }
38: 	} catch (IOException e) {
39: 	    System.err.println(e);
40: 	}
41: 	finally {
42: 	    if (ms != null) {
43: 		try {
44: 		    ms.leaveGroup(group);
45: 		    ms.close();
46: 		} catch (IOException io) { }
47: 	    }
48: 	}
49:     }
50: }
\end{verbatim}
